FROM python:3.11-slim

WORKDIR /app

# Install SSH server
RUN apt-get update && apt-get install -y openssh-server sudo && rm -rf /var/lib/apt/lists/*

# Setup SSH daemon
RUN mkdir -p /var/run/sshd

# Create user 'moham' with password 'password'
RUN useradd -rm -d /home/moham -s /bin/bash -g root -G sudo -u 1000 moham
RUN echo 'moham:password' | chpasswd

# Allow password authentication
RUN sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config

# Expose the standard SSH port
EXPOSE 22

# Start SSH daemon
CMD ["/usr/sbin/sshd", "-D"]
